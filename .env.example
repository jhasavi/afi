# Database (SQLite for local dev)
DATABASE_URL="file:./dev.db"

# Production: use PostgreSQL
# DATABASE_URL="postgresql://advisorflow:advisorflow@localhost:5432/advisorflow"

# Auth — required in production (min 32 chars)
AUTH_SECRET="dev-secret-please-change-in-production-0123456789abcdef"

# OpenAI (optional — template mode works without this)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Daily AI generation cap per user (0 = unlimited)
OPENAI_DAILY_GENERATION_CAP=50

# Feature flags (all default off)
FEATURE_GMAIL_SYNC=false
FEATURE_CRM_SYNC=false
FEATURE_SMS_SEND=false

NODE_ENV=development
