# Database (SQLite for local dev)
DATABASE_URL="file:./dev.db"

# Production: use PostgreSQL
# DATABASE_URL="postgresql://advisorflow:advisorflow@localhost:5432/advisorflow"

# Auth — required in production (min 32 chars)
AUTH_SECRET="dev-secret-please-change-in-production-0123456789abcdef"

# Public app URL (Stripe redirects, emails)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# OpenAI (optional — template mode works without this)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Daily AI generation cap per user (0 = unlimited). Monthly plan caps also apply.
OPENAI_DAILY_GENERATION_CAP=50

# Feature flags (all default off)
FEATURE_GMAIL_SYNC=false
FEATURE_CRM_SYNC=false
FEATURE_SMS_SEND=false

NODE_ENV=development

# Namaste Boston Mission Control sync (optional; Team plan required in-app)
NB_API_BASE_URL="http://localhost:3000"
NB_API_KEY=""

# Weekly NB auto-sync cron (Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=""

# Stripe billing (optional locally — see docs/BILLING.md)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_SOLO_PRO=""
STRIPE_PRICE_TEAM=""
